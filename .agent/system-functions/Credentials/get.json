{
  "description" : "Retrieves credential information by its key",
  "input" : {
    "type" : "object",
    "properties" : {
      "credentialKey" : {
        "type" : "string",
        "description" : "The key of the credential to retrieve"
      }
    },
    "required" : [ "credentialKey" ]
  },
  "output" : {
    "type" : "object",
    "description" : "Filtered credential object with essential fields, or undefined if the credential key doesn't exist",
    "properties" : {
      "id" : {
        "type" : "string",
        "description" : "Unique identifier of the credential"
      },
      "name" : {
        "type" : "string",
        "description" : "Name of the credential"
      },
      "key" : {
        "type" : "string",
        "description" : "Key of the credential"
      },
      "group" : {
        "type" : "string",
        "description" : "Group category of the credential",
        "enum" : [ "LLM", "CHANNEL", "FUNCTION", "CUSTOM" ]
      },
      "token" : {
        "type" : "string",
        "description" : "Token value (if applicable)"
      },
      "basicAuth" : {
        "type" : "object",
        "description" : "Basic authentication details (if applicable)",
        "properties" : {
          "username" : {
            "type" : "string",
            "description" : "Username for basic auth"
          },
          "password" : {
            "type" : "string",
            "description" : "Password for basic auth"
          }
        }
      },
      "expiredAt" : {
        "type" : "string",
        "description" : "Expiration timestamp",
        "format" : "date-time"
      }
    }
  }
}