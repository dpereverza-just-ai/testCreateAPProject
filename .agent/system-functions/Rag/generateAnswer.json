{
  "description" : "Generates an answer using a RAG integration based on a query",
  "input" : {
    "type" : "object",
    "properties" : {
      "ragIntegration" : {
        "type" : "string",
        "description" : ""
      },
      "query" : {
        "type" : "string",
        "description" : "The user query text"
      },
      "historyMessageLimit" : {
        "type" : "integer",
        "description" : "The maximum number of recent messages from the dialogue history."
      }
    },
    "required" : [ "ragIntegration", "query" ]
  },
  "output" : {
    "type" : "object",
    "description" : "Response containing the generated answer and related information",
    "properties" : {
      "id" : {
        "type" : "integer",
        "description" : "Request identifier"
      },
      "request" : {
        "type" : "string",
        "description" : "Text of the original user request"
      },
      "response" : {
        "type" : "string",
        "description" : "Response text generated by LLM"
      },
      "status" : {
        "type" : "string",
        "description" : "Processing status of the user query",
        "enum" : [ "READY_TO_PROCESS", "PROCESSING", "FINISHED", "FAILED", "CANCELED" ]
      },
      "createdAt" : {
        "type" : "string",
        "format" : "date-time",
        "description" : "Time when request processing started"
      },
      "updatedAt" : {
        "type" : "string",
        "format" : "date-time",
        "description" : "Time of the last request update"
      },
      "comment" : {
        "type" : "string",
        "description" : "Comment on the result of request processing"
      },
      "relevantSources" : {
        "type" : "array",
        "description" : "List of sources based on which the response was generated",
        "items" : {
          "type" : "object",
          "properties" : {
            "id" : {
              "type" : "integer",
              "description" : "Source identifier"
            },
            "path" : {
              "type" : "string",
              "description" : "Name of the source in the knowledge base"
            },
            "externalLink" : {
              "type" : "string",
              "description" : "Link to the source"
            }
          },
          "required" : [ "id", "path" ]
        }
      }
    },
    "required" : [ "id", "request", "status", "createdAt" ]
  }
}